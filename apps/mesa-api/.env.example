# ============================================================
# OBRIGATORIAS
# ============================================================

# PostgreSQL (Supabase Pooler em Transaction Mode)
DATABASE_URL=postgresql://postgres.project-ref:your-password@aws-1-us-west-2.pooler.supabase.com:6543/postgres

# ============================================================
# SUPABASE (Auth + Database)
# ============================================================

SUPABASE_URL=https://project-ref.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_service_role_xxxxxxxxxxxxxxxxxxxx

# ============================================================
# SERVIDOR
# ============================================================

PORT=8787

# ============================================================
# SEGURANCA — NUNCA COMITAR VALORES REAIS
# Gerar com: openssl rand -base64 64
# ============================================================

# Chave secreta para assinatura/verificacao de JWT internos
JWT_SECRET=replace_with_random_string_min_32_chars

# Token de deploy/integracao
DEPLOY_TOKEN=your_deploy_token_here

# ============================================================
# OPCIONAIS
# ============================================================

# Node env
NODE_ENV=development
