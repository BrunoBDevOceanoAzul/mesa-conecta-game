# ============================================================
# SUPABASE - Banco de dados, Auth e Serverless Functions
# ============================================================
# Obtenha em: https://supabase.com/dashboard
# Settings > API > Project URL e chaves

VITE_SUPABASE_URL=https://seu-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Backend (Supabase Functions)
SUPABASE_URL=https://seu-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Database Connection
DATABASE_URL=postgresql://postgres:senha@db.seu-project-id.supabase.co:5432/postgres


# ============================================================
# RESEND - Email transacional
# ============================================================
# Obtenha em: https://resend.com/overview > API Keys

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx


# ============================================================
# STRIPE - Pagamentos com Cartão de Crédito e Subscrições
# ============================================================
# Obtenha em: https://dashboard.stripe.com/apikeys (Modo TEST)

STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx


# ============================================================
# ASAAS - Pagamentos PIX, Boleto e Transações (Brasil)
# ============================================================
# Obtenha em: https://www.asaas.com > Configurações > Integrações > API

ASAAS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx


# ============================================================
# GOOGLE MAPS - Autocomplete de Endereços e Geolocalização
# ============================================================
# Obtenha em: https://console.cloud.google.com/ > Credenciais

GOOGLE_MAPS_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxx
VITE_GOOGLE_MAPS_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxx


# ============================================================
# LOVABLE - IA para Geração de Conteúdo
# ============================================================
# Obtenha em: https://lovable.dev > Settings > API Keys

LOVABLE_API_KEY=lav_xxxxxxxxxxxxxxxxxxxxxxxx


# ============================================================
# CONFIGURAÇÕES ADICIONAIS (Opcional)
# ============================================================

# URL base da aplicação (para webhooks e redirects)
VITE_APP_URL=http://localhost:5173

# Mesa API - Backend Node.js/Fastify
VITE_MESA_API_URL=http://localhost:8787

# Modo de desenvolvimento
VITE_ENV=development
