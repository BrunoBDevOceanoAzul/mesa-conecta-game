{
  "name": "socio-do-tabuleiro",
  "private": true,
  "version": "1.0.0",
  "description": "S\u00f3cio do Tabuleiro - Plataforma de conex\u00e3o para o universo tabletop",
  "type": "module",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --prefix=frontend",
    "dev:api": "npm run dev --workspace=backend",
    "build": "npm run build --prefix=frontend",
    "build:api": "npm run build --workspace=backend",
    "test": "npm run test --prefix=frontend",
    "test:api": "npm run test --workspace=backend",
    "lint": "npm run lint --prefix=frontend",
    "verify": "npm run typecheck --workspace=backend && npm run test --workspace=backend && npm run test --prefix=frontend"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "date-fns": "^2.30.0",
    "nanoid": "^5.1.9",
    "next": "^14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/google.maps": "^3.64.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7"
  }
}