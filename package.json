{
  "name": "socio-do-tabuleiro",
  "private": true,
  "version": "1.0.0",
  "description": "Sócio do Tabuleiro - Plataforma de conexão para o universo tabletop",
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "dev:api": "npm run dev --workspace=backend",
    "build": "npm run build --workspace=frontend",
    "build:api": "npm run build --workspace=backend",
    "test": "npm run test --workspace=frontend",
    "test:api": "npm run test --workspace=backend",
    "lint": "npm run lint --workspace=frontend",
    "verify": "npm run typecheck --workspace=backend && npm run test --workspace=backend && npm run test --workspace=frontend"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
