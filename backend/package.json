{
  "name": "mesa-api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "build:full": "cd .. && npm run build --workspace=frontend && npm run build --workspace=backend",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm test",
                    "test": "DATABASE_URL=${DATABASE_URL:-postgresql://mesa:mesa@localhost:5432/mesa_test} npm run build:tests && node --test $(find dist-test -name '*.test.js' -print)",
    "test:watch": "DATABASE_URL=${DATABASE_URL:-postgresql://mesa:mesa@localhost:5432/mesa_test} node --import tsx/esm --test --watch $(find src -name '*.test.ts' -print)",
    "build:tests": "tsc -p tsconfig.test.json",
    "db:introspect": "drizzle-kit introspect",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.7",
    "fastify": "^5.6.1",
    "postgres": "^3.4.7",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.9.0",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.7",
    "supertest": "^7.2.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
