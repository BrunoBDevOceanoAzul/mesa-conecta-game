# ============================================================
# OBRIGATORIAS
# ============================================================

# PostgreSQL (Supabase Pooler em Transaction Mode)
DATABASE_URL=postgresql://postgres.project-ref:your-password@aws-1-us-west-2.pooler.supabase.com:6543/postgres

# ============================================================
# SUPABASE (Auth + Database)
# ============================================================

SUPABASE_URL=https://project-ref.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_service_role_xxxxxxxxxxxxxxxxxxxx

# ============================================================
# SERVIDOR
# ============================================================

PORT=8787

# ============================================================
# SEGURANCA — NUNCA COMITAR VALORES REAIS
# Gerar com: openssl rand -base64 64
# ============================================================

# Chave secreta para assinatura/verificacao de JWT internos
JWT_SECRET=replace_with_random_string_min_32_chars

# ============================================================
# EMAIL (Resend)
# ============================================================

# Obter em: https://resend.com/overview > API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# CUSTOMER.IO — Email transacional e CDP
# ============================================================

# Obter em: Customer.io > Settings > API Credentials
CUSTOMERIO_APP_API_KEY=cio_app_xxxxxxxxxxxxxxxxxxxx
CUSTOMERIO_API_BASE_URL=https://api.customer.io/v1
CUSTOMERIO_TRANSACTIONAL_MESSAGE_ID=replace_with_customerio_transactional_message_id
# Opcional: mapeamento por template
CUSTOMERIO_TRANSACTIONAL_MESSAGE_IDS={"welcome":"replace_with_id","booking-confirmation":"replace_with_id"}
# Usar apenas se quiser enviar sem transactional_message_id categorizado
CUSTOMERIO_ALLOW_UNCATEGORIZED=false

# CDP/Pipelines source write key para identify/track
CUSTOMERIO_CDP_WRITE_KEY=replace_with_customerio_cdp_source_write_key
CUSTOMERIO_EVENTS_WRITE_KEY=replace_with_customerio_events_source_write_key
CUSTOMERIO_CDP_API_BASE_URL=https://cdp.customer.io/v1

# ============================================================
# PAGAMENTOS
# ============================================================

# Stripe (modo test)
# Obter em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

# Asaas (Brasil — PIX, Boleto)
# Obter em: https://www.asaas.com > Configuracoes > Integracoes > API
ASAAS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# OPCIONAIS
# ============================================================

# Token de deploy/integracao
DEPLOY_TOKEN=your_deploy_token_here

# Node env
NODE_ENV=development
